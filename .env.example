# ============================================================================
# aumos-govdef-overlay — Environment Variables
# Copy to .env and customize for local development
# ============================================================================

# Database
AUMOS_GOVDEF_DATABASE_URL=postgresql+asyncpg://aumos:aumos@localhost:5432/aumos_govdef

# Kafka
AUMOS_GOVDEF_KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Keycloak / Auth
AUMOS_GOVDEF_KEYCLOAK_URL=http://localhost:8080
AUMOS_GOVDEF_KEYCLOAK_REALM=aumos
AUMOS_GOVDEF_KEYCLOAK_CLIENT_ID=govdef-overlay

# FedRAMP configuration
AUMOS_GOVDEF_FEDRAMP_AGENCY_ID=
AUMOS_GOVDEF_FEDRAMP_IMPACT_LEVEL=moderate
AUMOS_GOVDEF_FEDRAMP_PMO_CONTACT=

# NIST 800-53 configuration
AUMOS_GOVDEF_NIST_BASELINE=moderate
AUMOS_GOVDEF_NIST_REVISION=rev5

# CMMC configuration
AUMOS_GOVDEF_CMMC_TARGET_LEVEL=3
AUMOS_GOVDEF_CMMC_C3PAO_ID=

# Sovereign Cloud configuration
AUMOS_GOVDEF_SOVEREIGN_CLOUD_PROVIDER=
AUMOS_GOVDEF_SOVEREIGN_REGION=

# Impact Level configuration
AUMOS_GOVDEF_MAX_IL_LEVEL=4
AUMOS_GOVDEF_CLASSIFIED_ENV_ENCRYPTION_KEY_ARN=

# Observability
AUMOS_GOVDEF_SENTRY_DSN=
AUMOS_GOVDEF_OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
